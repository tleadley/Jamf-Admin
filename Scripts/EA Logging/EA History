#!/bin/bash

LOG_PATH="/Library/Application Support/Digital Convergence/ea_history.csv"

if [ -f "$LOG_PATH" ]; then
    # Read the last 10 entries and reverse them so newest is on top
    HISTORY=$(tail -n 10 "$LOG_PATH" | sort -r)
    echo "<result>$HISTORY</result>"
else
    echo "<result>No log history found.</result>"
fi
